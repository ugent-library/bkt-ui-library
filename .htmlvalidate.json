{
  "root": true,
  "extends": ["html-validate:recommended"],
  "rules": {
    "missing-doctype": "off",
    "heading-level": "off",
    "no-trailing-whitespace": "off",
    "require-sri": "off",
    "no-inline-style": "off",
    "long-title": "off",

    "valid-autocomplete": "off",
    "input-attributes": "off",

    "aria-label-misuse": ["error", { "allowAnyNamable": true }],

    "prefer-native-element": "warn",
    "no-redundant-role": "warn",
    "no-redundant-for": "warn",

    "wcag/h71": "error",
    "wcag/h63": "error",
    "wcag/h37": "error",
    "input-missing-label": "error",
    "empty-heading": "error",
    "no-dup-id": "error"
  }
}
