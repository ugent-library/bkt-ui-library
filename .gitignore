# macOS
.DS_Store
.AppleDouble
.LSOverride

# FUSE mount artifacts — orphaned copies of files replaced while a process
# still held them open; safe to delete
.fuse_hidden*

# Node
node_modules/

# Build artifacts — compiled CSS is committed, source maps are not
*.css.map

# Fantasticon intermediate output — the real output is assets/scss/icons/_icon-font.scss
assets/fonts/icon-font.css

# AI settings and working context
.claude/